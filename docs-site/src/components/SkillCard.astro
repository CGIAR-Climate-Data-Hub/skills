---
export interface Props {
  name: string;
  slug: string;
  summary: string;
  kind: 'pipeline' | 'download' | 'processing' | 'visualization';
  tags: string[];
  runtime?: string;
}

const { name, slug, summary, kind, tags, runtime } = Astro.props;

const kindLabel: Record<string, string> = {
  pipeline:      'End-to-end pipeline',
  download:      'Data ingestion',
  processing:    'Spatial processing',
  visualization: 'Visualization',
};
---

<a href={`/skills/${slug}/`} class="cdh-card">
  <div class="cdh-card-header">
    <span class="cdh-card-name">{name}</span>
    <span class={`cdh-card-kind ${kind}`}>{kindLabel[kind]}</span>
  </div>

  <p class="cdh-card-summary">{summary}</p>

  <div class="cdh-card-tags">
    {tags.map((t) => <span class="cdh-tag">{t}</span>)}
  </div>

  <div class="cdh-card-footer">
    {runtime && <span>{runtime}</span>}
    <span class="cdh-arrow">→</span>
  </div>
</a>
